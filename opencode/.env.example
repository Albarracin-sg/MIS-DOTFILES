# OpenCode Environment Variables
# Copiar a .env y completar con tus keys reales

# OpenAI API (OpenCode usa modelo opus/sonnet)
OPENAI_API_KEY=sk-...

# Context7 para búsqueda de código
CONTEXT7_API_KEY=tu_context7_key

# GitHub Personal Access Token
GITHUB_TOKEN=tu_gh_token

# Stitch (diseño UI)
STITCH_API_KEY=tu_stitch_key

# Obsidian Local REST API
OBSIDIAN_API_KEY=tu_obsidian_api_key
OBSIDIAN_BASE_URL=http://127.0.0.1:27123
